  <name>Rhino Player</name>
  <summary>Desktop media player using mpv and GTK 4</summary>
  <description>
    <p>Rhino Player plays video and audio on Linux with libmpv, GTK 4, and libadwaita. It is aimed at the GNOME stack (Wayland or X11) and uses a full-color app icon in the Freedesktop hicolor theme.</p>
  </description>
  <launchable type="desktop-id">ch.rhino.RhinoPlayer.desktop</launchable>
  <url type="homepage">https://github.com/adrianov/rhino-player</url>
  <url type="bugtracker">https://github.com/adrianov/rhino-player/issues</url>
  <content_rating type="oars-1.1"/>
  <provides>
    <mediatype>video/mp4</mediatype>
    <mediatype>video/x-matroska</mediatype>
  </provides>
